PROJECT_NAME="Task Manager API"
API_V1_STR="/api/v1"
SECRET_KEY="your-secret-key-for-jwt-token-signing-use-a-strong-random-value"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
BACKEND_CORS_ORIGINS=["http://localhost:8000", "http://localhost:3000"]

# Database
# For SQLite, use: sqlite+aiosqlite:///./task_manager.db
# For PostgreSQL, use: postgresql+asyncpg://postgres:postgres@localhost:5432/task_manager
DATABASE_URL=sqlite+aiosqlite:///./task_manager.db
